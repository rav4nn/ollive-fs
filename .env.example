# ============================================================
# Provider selection: "anthropic" | "deepseek" | "openai"
# ============================================================
LLM_PROVIDER=deepseek

# --- Anthropic (only used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- DeepSeek (only used when LLM_PROVIDER=deepseek) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- OpenAI / any other OpenAI-compatible provider ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# ============================================================
# Postgres
# ============================================================
POSTGRES_USER=ollive
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=ollive

# ============================================================
# App config
# ============================================================
AGGREGATION_INTERVAL_SECONDS=60

# Comma-separated list of allowed origins for CORS.
ALLOWED_ORIGINS=http://localhost:3000,https://ollive.hardeep.cv

# Next.js -> backend URL (baked into the build).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Host port for the frontend container (override if 3000 is taken).
FRONTEND_PORT=3000

# Optional: override pricing (USD per 1M tokens). Defaults are per-provider.
# PRICE_PER_MILLION_INPUT_TOKENS=
# PRICE_PER_MILLION_OUTPUT_TOKENS=
