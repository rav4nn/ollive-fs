map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    server_name ollive.hardeep.cv;

    # /chat is non-streaming JSON
    location = /chat {
        proxy_pass http://127.0.0.1:30001;
        include /etc/nginx/snippets/ollive-proxy.conf;
        proxy_read_timeout 120s;
    }
    # /chat/stream is SSE — disable buffering so each token frame flushes.
    location = /chat/stream {
        proxy_pass http://127.0.0.1:30001;
        include /etc/nginx/snippets/ollive-proxy.conf;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 600s;
        chunked_transfer_encoding on;
    }

    location = /health     { proxy_pass http://127.0.0.1:30001; include /etc/nginx/snippets/ollive-proxy.conf; }
    location = /stats      { proxy_pass http://127.0.0.1:30001; include /etc/nginx/snippets/ollive-proxy.conf; }
    location ^~ /stats/    { proxy_pass http://127.0.0.1:30001; include /etc/nginx/snippets/ollive-proxy.conf; }
    location = /sessions   { proxy_pass http://127.0.0.1:30001; include /etc/nginx/snippets/ollive-proxy.conf; }
    location ^~ /sessions/ { proxy_pass http://127.0.0.1:30001; include /etc/nginx/snippets/ollive-proxy.conf; }

    location / {
        proxy_pass http://127.0.0.1:30000;
        include /etc/nginx/snippets/ollive-proxy.conf;
    }

    client_max_body_size 2m;

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/ollive.hardeep.cv/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/ollive.hardeep.cv/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = ollive.hardeep.cv) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    listen [::]:80;
    server_name ollive.hardeep.cv;
    return 404; # managed by Certbot
}
